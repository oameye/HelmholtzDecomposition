Notebook[{Cell["HelmholtzDecomposition", "ObjectName"], 
  Cell[BoxData[GridBox[{{Cell["HelmholtzDecomposition[f, xvec]", 
        "TableText"], Cell["returns a HelmholtzDecomposition object whose \
properties give the analytical Helmholtz decomposition f = g + r of the \
vector field f with respect to the coordinates xvec.", "TableText"]}}, 
     ColumnsEqual -> False]], "Usage"], 
  Cell[BoxData[GridBox[{{Cell["HelmholtzDecomposition[f]", "TableText"], 
       Cell["auto-detects the coordinates from the symbols appearing in f.", 
        "TableText"]}}, ColumnsEqual -> False]], "Usage"], 
  Cell[BoxData[GridBox[{{Cell["hd[\"prop\"]", "TableText"], 
       Cell[
        "returns the named property of a HelmholtzDecomposition object hd.", 
        "TableText"]}}, ColumnsEqual -> False]], "Usage"], 
  Cell["Details", "NotesSection"], Cell["The decomposition is constructed via \
the algorithm of Richters and Glotzl (J. Math. Anal. Appl. 525, 127138, \
2023). The algorithmic core handles polynomial, exponential, sine and cosine \
atomic terms; mixed transcendentals may need to be split by hand.", "Notes"], 
  Cell["The result is a wrapped Association with head HelmholtzDecomposition. \
It carries enough state to recover all derived quantities without \
recomputation.", "Notes"], 
  Cell["Available properties (queried via hd[\"name\"]):", "Notes"], 
  Cell["  \"Gradient\"               g, the curl-free component", "Notes"], 
  Cell["  \"Rotational\"             r, the divergence-free component", 
   "Notes"], Cell["  \"Potential\"              scalar P with Grad[P] == g", 
   "Notes"], Cell["  \"AntisymmetricPotential\" the antisymmetric matrix Rij \
whose row-divergence is r", "Notes"], 
  Cell["  \"VectorPotentialA\"       (3D only) vector A with Curl[A] == r", 
   "Notes"], 
  Cell["  \"PotentialMatrix\"        the underlying potential matrix Fij", 
   "Notes"], Cell["  \"Residual\"               f - g - r, simplified", 
   "Notes"], Cell["  \"Field\", \"Coordinates\"   the inputs", "Notes"], 
  Cell["  \"Verify\"                 <| GradientCurlFree, \
RotationalDivergenceFree, ResidualZero |>", "Notes"], 
  Cell["  \"Properties\"             list of the keys above", "Notes"], 
  Cell["  \"Association\"            the raw underlying Association", 
   "Notes"], Cell["List @@ hd returns {g, r}; Normal[hd] returns the \
underlying Association.", "Notes"], Cell["Options", "NotesSection"], 
  Cell["SimplificationFunction -> FullSimplify", "Notes"], 
  Cell["    Function applied to the components. Use Simplify for speed, \
Identity to skip simplification entirely.", "Notes"], 
  Cell["Assumptions :> $Assumptions", "Notes"], 
  Cell["    Forwarded to the simplifier.", "Notes"], 
  Cell["Verbose -> False", "Notes"], Cell["    When True, traces which atoms \
hit which branch of the algorithm via Echo.", "Notes"], 
  Cell["Caching -> True", "Notes"], Cell["    When True (default), memoizes \
results on (f, xvec, simp, asm). ClearHelmholtzCache[] empties the cache.", 
   "Notes"], Cell["Basic Examples", "PrimaryExamplesSection"], 
  Cell["Decompose a 2D polynomial field:", "Text"], 
  Cell[BoxData["hd = HelmholtzDecomposition[{x^2 + y, x y}, {x, y}]"], 
   "Input"], Cell[BoxData["hd[\"Gradient\"]"], "Input"], 
  Cell[BoxData["hd[\"Rotational\"]"], "Input"], 
  Cell[BoxData["hd[\"Potential\"]"], "Input"], 
  Cell[BoxData["hd[\"Verify\"]"], "Input"], 
  Cell["Auto-detect coordinates and recover the legacy {g, r} list:", 
   "Text"], Cell[BoxData["List @@ HelmholtzDecomposition[{x^2 + y, x y}]"], 
   "Input"], Cell["Pass assumptions to the simplifier:", "Text"], 
  Cell[BoxData["HelmholtzDecomposition[{a x^2, b y}, {x, y},\n  Assumptions \
-> a > 0 && b > 0][\"Potential\"]"], "Input"], Cell["3D vector potential A:", 
   "Text"], 
  Cell[BoxData[
    "HelmholtzDecomposition[{-y - z, x, 0}, {x, y, z}][\"VectorPotentialA\"]"]\
, "Input"], Cell["Source", "NotesSection"], Cell["Erhard Glotzl, Oliver \
Richters, \"Helmholtz decomposition and potential functions for n-dimensional \
analytic vector fields\", J. Math. Anal. Appl. 525, 127138 (2023). \
https://doi.org/10.1016/j.jmaa.2023.127138", "Notes"]}, 
 StyleDefinitions -> FrontEnd`FileName[{"Wolfram"}, "Reference.nb", 
   CharacterEncoding -> "UTF-8"]]
